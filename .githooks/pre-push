#!/bin/sh
IDENTITIES_FILE=".githooks/allowed-identities.txt"

name=$(git config --get user.name)
email=$(git config --get user.email)
identity="$name <$email>"

if [ ! -f "$IDENTITIES_FILE" ]; then
  echo "ERROR: identities file not found: $IDENTITIES_FILE" >&2
  exit 1
fi

if ! grep -Fqx "$identity" "$IDENTITIES_FILE"; then
  echo "ERROR: push blocked due to git identity mismatch" >&2
  echo "Current: $identity" >&2
  echo "Allowed identities are listed in $IDENTITIES_FILE" >&2
  exit 1
fi

# Проверяем только новые коммиты, которые реально пушатся.
while read local_ref local_sha remote_ref remote_sha
do
  if [ -z "$local_sha" ]; then
    continue
  fi

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  for c in $(git rev-list "$range"); do
    an=$(git show -s --format=%an "$c")
    ae=$(git show -s --format=%ae "$c")
    cn=$(git show -s --format=%cn "$c")
    ce=$(git show -s --format=%ce "$c")
    a_identity="$an <$ae>"
    c_identity="$cn <$ce>"
    if ! grep -Fqx "$a_identity" "$IDENTITIES_FILE"; then
      echo "ERROR: push blocked; new commit $c has unexpected identity" >&2
      echo "author: $a_identity" >&2
      exit 1
    fi
    if ! grep -Fqx "$c_identity" "$IDENTITIES_FILE"; then
      echo "ERROR: push blocked; new commit $c has unexpected identity" >&2
      echo "committer: $c_identity" >&2
      exit 1
    fi
  done
done

exit 0
