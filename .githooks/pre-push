#!/bin/sh
expected_name="Andrey"
expected_email="andreylikhatin@gmail.com"

name=$(git config --get user.name)
email=$(git config --get user.email)

if [ "$name" != "$expected_name" ] || [ "$email" != "$expected_email" ]; then
  echo "ERROR: push blocked due to git identity mismatch" >&2
  echo "Current: $name <$email>" >&2
  exit 1
fi

# Проверяем только новые коммиты, которые реально пушатся.
while read local_ref local_sha remote_ref remote_sha
do
  if [ -z "$local_sha" ]; then
    continue
  fi

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  for c in $(git rev-list "$range"); do
    an=$(git show -s --format=%an "$c")
    ae=$(git show -s --format=%ae "$c")
    cn=$(git show -s --format=%cn "$c")
    ce=$(git show -s --format=%ce "$c")
    if [ "$an" != "$expected_name" ] || [ "$ae" != "$expected_email" ] || [ "$cn" != "$expected_name" ] || [ "$ce" != "$expected_email" ]; then
      echo "ERROR: push blocked; new commit $c has unexpected identity" >&2
      echo "author: $an <$ae>; committer: $cn <$ce>" >&2
      exit 1
    fi
  done
done

exit 0
